#version 460 core
layout (std430, binding = 0) buffer buf {
	vec3 deeta[];
};

void main() {
	mat4 view = mat4(vec4(deeta[0], deeta[1].x), vec4(deeta[1].yz, deeta[2].xy), vec4(deeta[2].z, deeta[3]), vec4(0.0,0.0,0.0,1.0));
	uint id = gl_GlobalInvocationID.x+4;
	vec4 tmp = vec4(deeta[id], 1.0) * view;
	deeta[id] = tmp.xyz/tmp.w;
}